# Copy to `.env` in packages/gpt-sovits-trainer. 仅 gpt-sovits-trainer 读取。
# 默认：本地 smoke（2+2 epoch）；Colab 正式训练见「Colab 建议」。
#
# 加载：`uv run gpt-sovits-trainer` 启动时自动 load_dotenv

TRAINER_S1_EPOCHS=2
TRAINER_S2_EPOCHS=2
TRAINER_BATCH_SIZE=4
# Colab 建议: TRAINER_S1_EPOCHS=15  TRAINER_S2_EPOCHS=4  TRAINER_BATCH_SIZE=8

# 与 orchestrator 产物对齐；manbo 默认无需设置
# AI-Hobbyist 示例（jinxi）:
# TRAINER_WORKSPACE=ai_hobbyist/jinxi
# TRAINER_BASE_NAME=jinxi
# TRAINER_ZIP_STEM=jinxi_slices

# 留空则使用 vendor/GPT_SoVITS（推荐）
# GPT_SOVITS_ROOT=

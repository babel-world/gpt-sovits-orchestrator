# Copy to `.env` in this repo root.
# orchestrator 与 gpt-sovits-trainer 共用此文件。
#
# 一步到位（数据 + 训练）：
#   uv run gpt-sovits-orchestrator dry-vocal manbo
#   uv run gpt-sovits-orchestrator ai-hobbyist jinxi
#
# 仅训练（data/02–09 已就绪）：
#   uv run gpt-sovits-orchestrator dry-vocal manbo --trainer-only

# =============================================================================
# 服务地址（orchestrator）
# =============================================================================

ASR_SERVER_BASE_URL=http://127.0.0.1:19031
NLP_SERVER_BASE_URL=http://127.0.0.1:19032
TTS_SERVER_BASE_URL=http://127.0.0.1:19033

# =============================================================================
# HTTP 超时（秒）
# =============================================================================

SLICE_API_TIMEOUT_S=600
TRANSCRIBE_API_TIMEOUT_S=600
G2P_API_TIMEOUT_S=60
HUBERT_API_TIMEOUT_S=120
SV_API_TIMEOUT_S=120
V2PRO_API_TIMEOUT_S=120
SERVER_HEALTH_CHECK_TIMEOUT_S=10

# =============================================================================
# 切片 API（POST /api/audio/slice 的 Form 参数）
# =============================================================================

SLICE_THRESHOLD_DB=-40
SLICE_MIN_LENGTH_MS=5000
SLICE_MIN_INTERVAL_MS=300
SLICE_HOP_SIZE_MS=20
SLICE_MAX_SIL_KEPT_MS=5000
# Colab 建议（更短切片、更多样本时可试）: SLICE_MIN_LENGTH_MS=3000

# =============================================================================
# G2P / manifest 过滤
# =============================================================================

G2P_MODE=prosody
PRIVACY_ALLOWED_LANGUAGE=ja
PRIVACY_MIN_PROBABILITY=0.95

# =============================================================================
# 本地信号预处理（data/05/06/08；一般无需改）
# =============================================================================

LOAD_SR=32000
TARGET_SR=16000
PEAK_LIMIT=2.2
PEAK_NORM=0.95
NORM_MAX=0.95
NORM_ALPHA=0.5
NORM_SCALE=1145.14
INT16_SCALE=32768

# =============================================================================
# ai-hobbyist import 默认值
# =============================================================================

AI_HOBBYIST_DEFAULT_LANGUAGE=ja
AI_HOBBYIST_DEFAULT_PROBABILITY=0.99

# =============================================================================
# 训练（gpt-sovits-trainer → data/10）
# 默认 2+2 epoch smoke；Colab 正式训练见注释
# =============================================================================

TRAINER_S1_EPOCHS=2
TRAINER_S2_EPOCHS=2
TRAINER_BATCH_SIZE=4
# Colab 建议: TRAINER_S1_EPOCHS=15  TRAINER_S2_EPOCHS=4  TRAINER_BATCH_SIZE=8

# 训练超参（orchestrator 会在 data/09 完成后 subprocess 调 trainer）
# workspace / base_name / zip_stem 由 CLI `{pipeline} {speaker}` 自动推导，无需配置

# 留空则使用 packages/gpt-sovits-trainer/vendor/GPT_SoVITS
# GPT_SOVITS_ROOT=

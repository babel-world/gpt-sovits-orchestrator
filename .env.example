# Copy to `.env` in this repo root. Defaults match local smoke-test settings (manbo 验收).
# 仅 gpt-sovits-orchestrator 读取；trainer / 各 server 各有自己的 `.env.example`。
#
# 加载：`uv run gpt-sovits-orchestrator` 启动时自动 load_dotenv

# =============================================================================
# 服务地址
# =============================================================================

ASR_SERVER_BASE_URL=http://127.0.0.1:19031
NLP_SERVER_BASE_URL=http://127.0.0.1:19032
TTS_SERVER_BASE_URL=http://127.0.0.1:19033

# =============================================================================
# HTTP 超时（秒）
# =============================================================================

SLICE_API_TIMEOUT_S=600
TRANSCRIBE_API_TIMEOUT_S=600
G2P_API_TIMEOUT_S=60
HUBERT_API_TIMEOUT_S=120
SV_API_TIMEOUT_S=120
V2PRO_API_TIMEOUT_S=120
SERVER_HEALTH_CHECK_TIMEOUT_S=10

# =============================================================================
# 切片 API（POST /api/audio/slice 的 Form 参数）
# 默认与 asr-server 一致；本地 manbo 验收即此组值
# =============================================================================

SLICE_THRESHOLD_DB=-40
SLICE_MIN_LENGTH_MS=5000
SLICE_MIN_INTERVAL_MS=300
SLICE_HOP_SIZE_MS=20
SLICE_MAX_SIL_KEPT_MS=5000
# Colab 建议（更短切片、更多样本时可试）: SLICE_MIN_LENGTH_MS=3000

# =============================================================================
# G2P / manifest 过滤
# =============================================================================

G2P_MODE=prosody
PRIVACY_ALLOWED_LANGUAGE=ja
PRIVACY_MIN_PROBABILITY=0.95

# =============================================================================
# 本地信号预处理（data_05/06/08；一般无需改）
# =============================================================================

LOAD_SR=32000
TARGET_SR=16000
PEAK_LIMIT=2.2
PEAK_NORM=0.95
NORM_MAX=0.95
NORM_ALPHA=0.5
NORM_SCALE=1145.14
INT16_SCALE=32768

# =============================================================================
# AI-Hobbyist pipeline（gpt-sovits-orchestrator-ai-hobbyist）
# 将 wav+lab 拷贝到 .local/ai_hobbyist/{speaker}/inbox/ 后运行
# =============================================================================

# AI_HOBBYIST_SPEAKER=jinxi
# 可选：直接指向外部 wav+lab 目录，跳过拷贝到 workspace inbox
# AI_HOBBYIST_INBOX_DIR=E:\WorkSpace\Projects_GitHub\AI-Hobbyist\WutheringWaves2.2_JP\日语 - Japanese\今汐
AI_HOBBYIST_DEFAULT_LANGUAGE=ja
AI_HOBBYIST_DEFAULT_PROBABILITY=0.99
